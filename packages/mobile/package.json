{
  "name": "@framesync/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "test": "vitest --run || true",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@expo/ui": "^0.2.0-beta.7",
    "@framesync/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@react-native-community/cli": "^20.0.2",
    "axios": "^1.7.7",
    "expo": "~54.0.22",
    "expo-constants": "~18.0.0",
    "expo-file-system": "~19.0.0",
    "expo-linking": "~8.0.8",
    "expo-media-library": "~18.2.0",
    "expo-router": "~6.0.14",
    "jotai": "^2.10.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "oxfmt": "^0.2.0",
    "oxlint": "^0.9.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "expo": {
    "name": "FrameSync",
    "slug": "framesync",
    "scheme": "framesync",
    "entryPoint": "expo-router/entry",
    "plugins": [
      "expo-router"
    ],
    "ios": {
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "FrameSync needs access to your Photos to send images to your TV.",
        "NSLocalNetworkUsageDescription": "FrameSync connects to your Samsung Frame TV on the local network."
      }
    }
  }
}
